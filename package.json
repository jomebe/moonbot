{
  "name": "moonbot-unciv-turn-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Unciv 멀티플레이 현재 차례 조회 Discord 봇 MVP",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "register:commands": "tsx src/registerCommands.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
